# Playwright persistent browser profile (contains your logged-in session!)
.costco_profile/

# All generated/downloaded data: raw receipts, parsed CSVs, PDFs, markdown,
# captures, fetch summaries — and credentials.json / api_headers.json /
# api_request.json. Never commit any of it.
data/

# Credentials / captured requests (belt-and-suspenders if data/ is relocated)
**/credentials.json
**/api_headers.json
**/api_request.json
*.curl

# All PDFs (receipt samples / exports contain member #, card digits) and any
# exported receipt JSON.
*.pdf
costco_receipts*.json

# Python
__pycache__/
*.pyc
.venv/
venv/
.env
